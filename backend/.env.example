# NeuralCanvas backend configuration. Copy to .env and adjust as needed.

# Port the FastAPI backend listens on (8001 by default to avoid LocalMind's 8000).
NEURALCANVAS_PORT=8001

# Ollama base URL (used by the Ollama embedding backend). IPv4 loopback avoids a
# possible IPv6 (::1) resolution stall on Windows.
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Set to 1 for DEBUG-level logs (individual events, internal state).
NEURALCANVAS_DEBUG=0
