# Public URL of the NeuralCanvas backend the frontend should call.
# Set this to your ngrok static domain (tunnelling local port 8001). For local
# dev you can omit it entirely and the app falls back to http://localhost:8001.
VITE_API_URL=https://your-static-domain.ngrok-free.dev
# Reserve a static domain in the ngrok dashboard, then expose the backend with:
#   ngrok http 8001 --url=https://your-static-domain.ngrok-free.dev
